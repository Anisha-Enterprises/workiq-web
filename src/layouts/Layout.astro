---
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "WorkIQ"
  : "WorkIQ - Strategic Workforce Solutions | IT Recruitment & HR Outsourcing";

const description = "WorkIQ is a national-level workforce solutions firm offering IT recruitment, non-IT staffing, executive search, HR outsourcing, and payroll compliance services across India.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{makeTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content="WorkIQ - Strategic Workforce Solutions" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedImageWithDomain} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="WorkIQ - Strategic Workforce Solutions" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={makeTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImageWithDomain} />
    <Analytics />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <SpeedInsights />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
