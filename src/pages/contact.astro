---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact</Fragment>
      <Fragment slot="desc">We are a here to help.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">Contact WorKIQ</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          Have a staffing requirement or need workforce solutions? We are here to help.
          Fill up the form or reach out directly.
        </p>
        <div class="mt-5">
          <div class="flex items-start mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4 mt-1 shrink-0" name="uil:map-marker" />
            <span>PL NO 3 AR, Hyder Nagar, KPHB Colony, Hyderabad, Telangana, India, 500085</span>
          </div>
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" />
            <a href="mailto:hello@workiq.in">hello@workiq.in</a>
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
