---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
---

<Layout title="About">
  <Container>
    <Sectionhead>
      <Fragment slot="title">About Us</Fragment>
      <Fragment slot="desc">
        A national-level workforce solutions firm driving measurable business outcomes.
      </Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-6 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-[var(--color-navy)]" style="font-family: var(--font-heading);">
        Who We Are
      </h2>
      <p class="text-lg leading-relaxed text-[var(--color-text-secondary)]">
        WorkIQ is a strategic workforce solutions firm specializing in
        end-to-end talent acquisition and HR management across IT and Non-IT sectors.
        With a compliance-first approach and structured methodologies, we help
        organizations build high-performing teams that drive business growth.
      </p>
      <p class="text-lg leading-relaxed text-[var(--color-text-secondary)]">
        From executive search and permanent staffing to HR outsourcing and payroll
        compliance, we deliver measurable outcomes backed by deep domain expertise
        and a pan-India operational presence.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 mx-auto max-w-4xl mt-16">
      <div class="bg-[var(--color-surface)] rounded-xl p-8 text-center">
        <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">Our Mission</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          To empower businesses with the right talent at the right time, ensuring
          compliance, quality, and long-term workforce sustainability.
        </p>
      </div>
      <div class="bg-[var(--color-surface)] rounded-xl p-8 text-center">
        <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">Our Vision</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          To be India's most trusted workforce solutions partner, known for
          operational excellence and measurable impact.
        </p>
      </div>
      <div class="bg-[var(--color-surface)] rounded-xl p-8 text-center">
        <h3 class="font-bold text-lg text-[var(--color-navy)] mb-2">Our Values</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          Integrity, compliance rigor, domain expertise, and an unwavering
          commitment to delivering results for every client engagement.
        </p>
      </div>
    </div>
  </Container>
</Layout>
