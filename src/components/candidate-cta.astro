---
import Link from "@/components/ui/link.astro";
---

<section id="candidate-cta" class="py-16 bg-[var(--color-surface)]">
  <div class="max-w-(--breakpoint-xl) mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-4">
        For Candidates
      </p>
      <h2
        class="text-3xl md:text-4xl font-bold text-[var(--color-navy)] text-balance"
        style="font-family: var(--font-heading);">
        Advance Your Career with the Right Opportunity
      </h2>
      <p class="text-lg mt-4 text-[var(--color-text-secondary)] max-w-xl mx-auto leading-relaxed">
        We connect professionals with roles that match their expertise, ambition, and growth
        trajectory. Confidential, structured, and career-focused.
      </p>
      <div class="mt-8">
        <Link
          href="/contact"
          size="lg"
          class="!px-10 !py-4 text-base font-semibold inline-flex items-center justify-center">
          Submit Your Profile
        </Link>
      </div>
    </div>
  </div>
</section>
