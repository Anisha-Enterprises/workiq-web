---
const services = [
  {
    title: "IT Recruitment",
    description:
      "Precision hiring across software engineering, data science, cloud infrastructure, cybersecurity, and emerging technology domains. We map technical competencies to your architecture and team culture.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"/></svg>`,
  },
  {
    title: "Non-IT Recruitment",
    description:
      "Strategic talent acquisition for operations, manufacturing, sales, finance, supply chain, and administrative functions. Sector-specific sourcing with deep domain understanding.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
  },
  {
    title: "Executive Search",
    description:
      "Confidential leadership hiring for C-suite, VP, and director-level roles. Rigorous assessment frameworks ensure cultural alignment and strategic fit at every level.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    title: "HR Outsourcing",
    description:
      "Comprehensive human resource management including onboarding, employee lifecycle administration, policy frameworks, and performance management systems.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/></svg>`,
  },
  {
    title: "Payroll & Compliance",
    description:
      "End-to-end payroll processing, statutory compliance management, and regulatory adherence. Ensuring your workforce operations meet every legal requirement seamlessly.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
];
---

<section id="services" class="py-20">
  <div class="max-w-(--breakpoint-xl) mx-auto px-5">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-4">
        What We Deliver
      </p>
      <h2
        class="text-3xl md:text-4xl font-bold text-[var(--color-navy)] text-balance"
        style="font-family: var(--font-heading);">
        Core Services
      </h2>
      <p class="text-lg mt-4 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        Integrated workforce solutions designed to align talent strategy with business objectives.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class="group bg-[var(--color-white)] border border-[var(--color-border-subtle)] rounded-lg p-8 hover:border-[var(--color-accent)] transition-all duration-300 hover:shadow-lg">
            <div class="w-12 h-12 rounded-lg bg-[var(--color-navy)] flex items-center justify-center text-[var(--color-accent)] mb-5">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-xl font-bold text-[var(--color-navy)] mb-3" style="font-family: var(--font-heading);">
              {service.title}
            </h3>
            <p class="text-[var(--color-text-secondary)] leading-relaxed text-sm">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
