---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const styles = {
  outline: "bg-transparent border-2 border-[var(--color-navy)] hover:bg-[var(--color-navy)] hover:text-white text-[var(--color-navy)] transition-colors",
  primary: "bg-[var(--color-navy)] text-white hover:bg-[var(--color-navy-light)] border-2 border-transparent transition-colors",
  inverted: "bg-[var(--color-white)] text-[var(--color-navy)] hover:bg-gray-100 border-2 border-transparent transition-colors",
  muted: "bg-[var(--color-surface)] hover:bg-gray-200 text-[var(--color-text-primary)] border-2 border-transparent transition-colors",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "rounded-sm text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
