---
const differentiators = [
  {
    title: "Strategic Workforce Alignment",
    description: "We align talent acquisition with your business roadmap — not just immediate vacancies, but long-term organizational design.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/></svg>`,
  },
  {
    title: "Compliance Rigor",
    description: "Full statutory compliance across labor laws, PF, ESI, PT, and payroll regulations — zero tolerance for non-adherence.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    title: "Dedicated Account Management",
    description: "Every client engagement is led by a dedicated account manager ensuring continuity, accountability, and proactive communication.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>`,
  },
  {
    title: "Scalable Operations",
    description: "From single critical hires to large-scale volume recruitment drives — our infrastructure flexes to meet demand without compromising quality.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>`,
  },
  {
    title: "Market Intelligence",
    description: "Real-time compensation benchmarking, talent availability insights, and competitive landscape analysis to inform hiring decisions.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
  },
  {
    title: "Retention Focus",
    description: "Our engagement does not end at placement. Post-hire monitoring, engagement tracking, and replacement guarantees protect your investment.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
  },
];
---

<section id="why-us" class="py-20 bg-[var(--color-surface)]">
  <div class="max-w-(--breakpoint-xl) mx-auto px-5">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-4">
        The Anisha Advantage
      </p>
      <h2
        class="text-3xl md:text-4xl font-bold text-[var(--color-navy)] text-balance"
        style="font-family: var(--font-heading);">
        Why Choose Anisha Enterprises
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
      {
        differentiators.map((item) => (
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-navy)] flex items-center justify-center text-[var(--color-accent)] shrink-0 mt-1">
              <Fragment set:html={item.icon} />
            </div>
            <div>
              <h3 class="text-lg font-bold text-[var(--color-navy)] mb-2" style="font-family: var(--font-heading);">
                {item.title}
              </h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
