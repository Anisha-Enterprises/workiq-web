---
import Link from "@/components/ui/link.astro";
---

<section id="employer-cta" class="py-20 bg-[var(--color-navy)]">
  <div class="max-w-(--breakpoint-xl) mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-accent)] mb-4">
        For Employers
      </p>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-white)] text-balance"
        style="font-family: var(--font-heading);">
        Ready to Build a Workforce That Delivers?
      </h2>
      <p class="text-lg mt-6 text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Partner with Anisha Enterprises for a structured, compliant, and results-driven approach
        to talent acquisition. Let us align your hiring strategy with your business vision.
      </p>
      <div class="mt-10">
        <Link
          href="/contact"
          size="lg"
          style="inverted"
          class="!px-10 !py-4 text-base font-semibold inline-flex items-center justify-center">
          Schedule a Consultation
        </Link>
      </div>
    </div>
  </div>
</section>
